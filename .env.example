# Beam Network Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
# Choose ONE network configuration below (uncomment the one you want)

# -----------------------------------------------------------------------------
# TESTNET (Subnet 304)
# -----------------------------------------------------------------------------
# Shared settings (used by orchestrator directly)
SUBNET_CORE_URL=https://beamcore-dev.b1m.ai
# Worker WebSocket/buffer endpoint. Set this separately when WS is not served by SUBNET_CORE_URL.
BUFFER_URL=http://api.beamcore.b1m.ai:8080
SUBTENSOR_NETWORK=test
NETUID=304

# Shared settings with BEAM_ prefix (used by validator via validation_alias)
BEAM_NETUID=304
BEAM_SUBTENSOR_NETWORK=test

# -----------------------------------------------------------------------------
# MAINNET (Subnet 105) - Uncomment these and comment out TESTNET above
# -----------------------------------------------------------------------------
# SUBNET_CORE_URL=https://beamcore.b1m.ai
# BUFFER_URL=http://api.beamcore.b1m.ai:8081
# SUBTENSOR_NETWORK=finney
# NETUID=105
# BEAM_NETUID=105
# BEAM_SUBTENSOR_NETWORK=finney

# =============================================================================
# LOCAL DEVELOPMENT MODE
# =============================================================================
# Skip Bittensor wallet/subtensor initialization (shared by both)
# LOCAL_MODE=true

# =============================================================================
# ORCHESTRATOR CONFIGURATION (no prefix)
# =============================================================================
# Orchestrator uses direct env names without prefix
#
# Quick start (run from neurons/orchestrator directory):
#   cd neurons/orchestrator && \
#   WALLET_NAME=your_coldkey \
#   WALLET_HOTKEY=your_hotkey \
#   SUBTENSOR_NETWORK=test \
#   NETUID=304 \
#   SUBNET_CORE_URL=https://beamcore-dev.b1m.ai \
#   REGISTRY_URL=https://beamcore-dev.b1m.ai \
#   python main.py

# Wallet
WALLET_NAME=orchestrator
WALLET_HOTKEY=default
# WALLET_PATH=~/.bittensor/wallets

# API Settings
# ORCHESTRATOR_HOST=0.0.0.0
# API_PORT=8000

# Registry URL (should match SUBNET_CORE_URL)
# Testnet:
REGISTRY_URL=https://beamcore-dev.b1m.ai
# Mainnet (uncomment for production):
# REGISTRY_URL=https://beamcore.b1m.ai

# Worker Management
# MAX_WORKERS=10000
# WORKER_TIMEOUT=300
# MIN_WORKER_BANDWIDTH=10.0

# Fee percentage (0.0 to 100.0)
# FEE_PERCENTAGE=5.0

# =============================================================================
# VALIDATOR CONFIGURATION (BEAM_VALIDATOR_ prefix)
# =============================================================================
# Validator uses BEAM_VALIDATOR_ prefix for most settings
#
# Quick start (run from neurons/validator directory):
#   cd neurons/validator && \
#   BEAM_VALIDATOR_WALLET_NAME=your_coldkey \
#   BEAM_VALIDATOR_WALLET_HOTKEY=your_hotkey \
#   BEAM_VALIDATOR_SUBNET_CORE_URL=https://beamcore-dev.b1m.ai \
#   python main.py

# Wallet (BEAM_VALIDATOR_ prefix)
BEAM_VALIDATOR_WALLET_NAME=validator
BEAM_VALIDATOR_WALLET_HOTKEY=default
# BEAM_VALIDATOR_WALLET_PATH=~/.bittensor/wallets

# Network (testnet)
BEAM_VALIDATOR_SUBNET_CORE_URL=https://beamcore-dev.b1m.ai
# Network (mainnet - uncomment for production)
# BEAM_VALIDATOR_SUBNET_CORE_URL=https://beamcore.b1m.ai

# BEAM_VALIDATOR_PORT=8093

# Validation Settings
# BEAM_VALIDATOR_TASK_INTERVAL_SECONDS=12
# BEAM_VALIDATOR_TASKS_PER_EPOCH=10
# BEAM_VALIDATOR_CHUNK_SIZE_BYTES=10485760

# Weight Setting
# BEAM_VALIDATOR_BLOCKS_BETWEEN_WEIGHTS=100
# BEAM_VALIDATOR_WEIGHT_ALPHA=0.3
# BEAM_VALIDATOR_MIN_CONNECTION_STAKE=10.0

# Logging
# BEAM_VALIDATOR_LOG_LEVEL=INFO
# BEAM_VALIDATOR_DEBUG=false

# =============================================================================
# DATABASE (Optional - for local persistence)
# =============================================================================

# PostgreSQL connection string (works for both, checked without prefix as fallback)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/beam

# =============================================================================
# REDIS (Optional - for caching/clustering)
# =============================================================================

# Redis URL
# REDIS_URL=redis://localhost:6379
