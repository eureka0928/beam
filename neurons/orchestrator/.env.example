# BEAM Orchestrator Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
# Choose ONE network configuration below (uncomment the one you want)

# -----------------------------------------------------------------------------
# TESTNET (Subnet 304)
# -----------------------------------------------------------------------------
SUBNET_CORE_URL=https://beamcore-dev.b1m.ai
SUBTENSOR_NETWORK=test
NETUID=304

# -----------------------------------------------------------------------------
# MAINNET (Subnet 105) - Uncomment these and comment out TESTNET above
# -----------------------------------------------------------------------------
# SUBNET_CORE_URL=https://beamcore.b1m.ai
# SUBTENSOR_NETWORK=finney
# NETUID=105

# =============================================================================
# WALLET CONFIGURATION
# =============================================================================
WALLET_NAME=orchestrator
WALLET_HOTKEY=default
WALLET_PATH=~/.bittensor/wallets

# =============================================================================
# API SETTINGS
# =============================================================================
API_PORT=8000
LOG_LEVEL=INFO

# Local mode - skip Bittensor wallet initialization (for development)
LOCAL_MODE=false

# =============================================================================
# FEE SETTINGS
# =============================================================================
# Percentage of emission shared with workers (0-100)
FEE_PERCENTAGE=0.0

# =============================================================================
# WORKER MANAGEMENT
# =============================================================================
MAX_WORKERS=10000
WORKER_TIMEOUT=300
MIN_WORKER_BANDWIDTH=10.0
WORKER_HEARTBEAT_INTERVAL=30

# =============================================================================
# TASK SETTINGS
# =============================================================================
MAX_CONCURRENT_TASKS=1000
TASK_TIMEOUT=120

# =============================================================================
# DATABASE (Optional - for local persistence)
# =============================================================================
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/beam
# REDIS_URL=redis://localhost:6379
